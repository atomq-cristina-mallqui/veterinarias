# LLM Provider (default: OpenAI)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5.4-nano-2026-03-17
LLM_PROVIDER=openai

# Gemini (opcional, solo si usarás LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your-gemini-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GEMINI_MODEL=gemini-2.5-flash

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
# Connection string Postgres (solo necesaria para `python scripts/init_db.py`)
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-db-password@aws-1-your-region.pooler.supabase.com:5432/postgres?sslmode=require
# Demo / desarrollo
DEMO_USER_ID=user_demo_1
CLINIC_TIMEZONE=America/Lima
CLINIC_CURRENCY=PEN

# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token-here
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here
WHATSAPP_VERIFY_TOKEN=choose-a-random-secret-verify-token
WHATSAPP_API_VERSION=v23.0
